# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_PORT=8000
API_HOST=0.0.0.0
WORKERS=4

# Authentication
JWT_SECRET_KEY=super-secret-jwt-key-for-development-only-32-chars!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_HEADER_NAME=X-API-Key
MFA_ENABLED=false
MFA_ISSUER_NAME="Enterprise Security Orchestrator Dev"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STRATEGY=sliding-window
RATE_LIMIT_REDIS_PREFIX=rate_limit:

# Encryption
TLS_ENABLED=false
FIELD_ENCRYPTION_KEY=dev-encryption-key-32-chars-long!!
FIELD_ENCRYPTION_ALGORITHM=AES-256-GCM
DB_ENCRYPTION_ENABLED=false

# Database
POSTGRES_DSN=postgresql://axr:axr@localhost:5432/axr
REDIS_DSN=redis://localhost:6379/0
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT=30
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=1

# Observability
SERVICE_NAME=security-orchestrator
LOG_LEVEL=INFO
LOG_FORMAT=console
TRACES_ENABLED=false
METRICS_ENABLED=true
METRICS_PORT=9090
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log

# Security - Use comma-separated strings, not JSON arrays
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
ALLOWED_HOSTS=localhost,127.0.0.1
SECURITY_HEADERS_ENABLED=false
HSTS_ENABLED=false
MAX_REQUEST_SIZE=10485760
MAX_REQUEST_BODY_LIMIT=10485760
IP_WHITELIST=
IP_BLACKLIST=

# LLM Configuration (optional)
LLM_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=Qwen2.5:3B

# Memory Configuration (optional)
VECTOR_DB_TYPE=mock
GRAPH_DB_TYPE=mock
TIMESERIES_DB_TYPE=mock

# Feature Flags - must be valid JSON string
FEATURES_ENABLED={"hybrid_execution":true,"audit_logging":true,"mfa":false,"webhooks":true,"scheduling":true}


# ========= AUTH =========
JWT_SECRET_KEY=supersecretkey123
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========= ENCRYPTION =========
FIELD_ENCRYPTION_KEY=my-super-secret-encryption-key

# ========= OBSERVABILITY =========
ENVIRONMENT=development
SERVICE_NAME=axr

# ========= LLM =========
LLM_PROVIDER=local
OPENAI_API_KEY=dummy
ANTHROPIC_API_KEY=dummy
# Worker Pool Configuration
MIN_WORKERS_PER_TOOL=1
MAX_WORKERS_PER_TOOL=2
SCALE_UP_THRESHOLD=0.8
SCALE_DOWN_THRESHOLD=0.1