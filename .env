# ========== Environment ==========
ENVIRONMENT=development
DEBUG=true
API_VERSION=v1
API_PORT=8000
API_HOST=0.0.0.0
WORKERS=4

# ========== Database ==========
POSTGRES_DSN=postgresql://user:password@localhost:5432/orchestrator
REDIS_DSN=redis://:password@localhost:6379/0
MONGODB_DSN=mongodb://localhost:27017/orchestrator

# ========== Authentication ==========
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_HEADER_NAME=X-API-Key
MFA_ENABLED=false
MFA_ISSUER_NAME="Enterprise Security Orchestrator"

# ========== Rate Limiting ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STRATEGY=sliding-window
REDIS_PASSWORD=redis-password-change-me

# ========== Encryption ==========
TLS_ENABLED=false
FIELD_ENCRYPTION_KEY=your-32-char-encryption-key-change
DB_ENCRYPTION_ENABLED=true

# ========== Observability ==========
SERVICE_NAME=security-orchestrator
LOG_LEVEL=INFO
LOG_FORMAT=json
OTLP_ENDPOINT=http://jaeger:4317
TRACES_ENABLED=true
TRACES_SAMPLE_RATE=0.1
METRICS_ENABLED=true
METRICS_PORT=9090
AUDIT_LOG_ENABLED=true

# ========== Security ==========
CORS_ORIGINS=http://localhost:3000,https://app.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
MAX_REQUEST_SIZE=10485760  # 10MB

# ========== Feature Flags ==========
FEATURES_ENABLED={"hybrid_execution":true,"audit_logging":true,"mfa":false,"webhooks":true,"scheduling":true}

# ========== Worker Configuration ==========
MIN_WORKERS_PER_TOOL=2
MAX_WORKERS_PER_TOOL=10
WORKER_SCALE_UP_THRESHOLD=0.7
WORKER_SCALE_DOWN_THRESHOLD=0.2
MAX_CONCURRENT_TASKS_PER_LEVEL=5

# ========== Circuit Breaker Configuration ==========
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# ========== Retry Configuration ==========
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1
RETRY_MAX_DELAY=60
RETRY_BACKOFF_FACTOR=2

# ========== Escalation Configuration ==========
ESCALATION_SLACK_WEBHOOK_URL=
ESCALATION_PAGERDUTY_KEY=
ESCALATION_EMAIL_RECIPIENTS=admin@example.com

# ========== Observability ==========
OTLP_ENDPOINT=http://tempo:4317
PYROSCOPE_ENDPOINT=http://pyroscope:4040
TRACES_SAMPLE_RATE=0.1
METRICS_ENABLED=true
AUDIT_LOG_PATH=/var/log/audit.log
AUDIT_SIGNING_KEY=your-audit-signing-key-change-in-production

# ========== Security ==========
VAULT_URL=http://vault:8200
VAULT_TOKEN=your-vault-token
RBAC_CACHE_TTL=300
ABAC_POLICY_PATH=/etc/policies

# ========== Monitoring ==========
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
PAGERDUTY_SERVICE_KEY=your-pagerduty-key
ALERT_WEBHOOK_URL=https://alerts.example.com/webhook

# ========== Governance ==========
DATA_RETENTION_DAYS=90
ARCHIVE_ENABLED=true
COMPLIANCE_FRAMEWORKS=soc2,gdpr,pci_dss

# ========== API Gateway ==========
API_RATE_LIMIT_DEFAULT=100/minute
API_KEY_EXPIRY_DAYS=365
API_DOCS_ENABLED=true
API_VERSIONING_ENABLED=true

# ========== Multi-Tenancy ==========
TENANT_ISOLATION_LEVEL=strict  # strict, soft, none
DEFAULT_TENANT_TIER=basic
MAX_TENANTS=1000
CROSS_TENANT_COLLABORATION=false

# ========== Integrations ==========
# SIEM
SPLUNK_URL=https://splunk.example.com:8089
SPLUNK_HEC_TOKEN=your-hec-token
QRADAR_URL=https://qradar.example.com
QRADAR_API_KEY=your-api-key

# Ticketing
JIRA_URL=https://jira.example.com
JIRA_USERNAME=integration
JIRA_API_TOKEN=your-api-token
SERVICENOW_URL=https://service-now.example.com
SERVICENOW_USERNAME=integration
SERVICENOW_PASSWORD=your-password

# Cloud
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_REGION=us-east-1
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ========== Workflow ==========
WORKFLOW_SLA_ENABLED=true
WORKFLOW_MAX_STEPS=50
WORKFLOW_TIMEOUT_SECONDS=3600
APPROVAL_TIMEOUT_HOURS=24

# ========== Reporting ==========
REPORT_RETENTION_DAYS=90
REPORT_SCHEDULER_ENABLED=true
REPORT_MAX_SIZE_MB=50
REPORT_STORAGE_PATH=/var/reports

# ========== AI/ML Configuration ==========
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_REGISTRY_PATH=/models
FEATURE_STORE_REDIS_URL=redis://feature-store:6379

# ========== Model Training ==========
TRAINING_DATA_RETENTION_DAYS=90
AUTO_RETRAIN_ENABLED=true
RETRAIN_INTERVAL_HOURS=168  # Weekly
MIN_TRAINING_SAMPLES=1000

# ========== Prediction Settings ==========
VULN_PREDICTION_CONFIDENCE_THRESHOLD=0.7
RISK_SCORE_UPDATE_INTERVAL=3600  # Hourly
PREDICTION_CACHE_TTL=86400  # 24 hours

# ========== Autonomous Operations ==========
SELF_HEALING_ENABLED=true
MAX_HEALING_ATTEMPTS=3
AUTO_SCALE_ENABLED=true
SCALE_COOLDOWN_SECONDS=300
PRIORITY_REBALANCE_INTERVAL=3600

# ========== Recommendation Engine ==========
RECOMMENDATION_CACHE_SIZE=1000
MIN_RECOMMENDATION_CONFIDENCE=0.6
LEARNING_RATE=0.01

# ========== Knowledge Graph ==========
GRAPH_EMBEDDING_DIM=128
PATTERN_MIN_SUPPORT=10
SIMILARITY_THRESHOLD=0.8