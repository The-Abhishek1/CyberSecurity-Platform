# ============================================
# API CONTAINER - Lightweight, Secure
# Size: ~200MB
# ============================================

# Build stage
FROM python:3.11-slim AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libffi-dev \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install poetry
RUN pip install --no-cache-dir poetry==1.5.1

# Copy dependency files
COPY pyproject.toml poetry.lock ./

# Install ONLY core dependencies (no ML, no LLM)
RUN poetry config virtualenvs.create false \
    && poetry install --no-interaction --no-ansi --no-root --only main

# Final secure image - using distroless (no shell, no package manager)
FROM gcr.io/distroless/python3-debian12:nonroot

WORKDIR /app

# Copy only necessary files from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code (only API-related code)
COPY src/api/ ./src/api/
COPY src/scheduler/ ./src/scheduler/
COPY src/agents/planner/ ./src/agents/planner/
COPY src/agents/verifier/ ./src/agents/verifier/
COPY src/tools/ ./src/tools/
COPY src/workers/worker_pool.py ./src/workers/
COPY src/workers/container_manager.py ./src/workers/
COPY src/workers/network_manager.py ./src/workers/
COPY src/workers/resource_monitor.py ./src/workers/
COPY src/core/ ./src/core/
COPY src/models/ ./src/models/
COPY src/utils/ ./src/utils/
COPY alembic/ ./alembic/
COPY alembic.ini ./

# Security: Non-root user already set by distroless
USER nonroot:nonroot

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD ["/usr/bin/curl", "-f", "http://localhost:8000/api/v1/health"]

# Run API
CMD ["uvicorn", "src.api.app:app", "--host", "0.0.0.0", "--port", "8000"]